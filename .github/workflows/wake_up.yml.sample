name: Wake Up Streamlit Apps

on:
  push:
    branches:
      - main
  schedule:
    - cron: "0 */6 * * *"

jobs:
  wake-up:
    runs-on: ubuntu-latest
    env:
      WAKE_INTERVAL_HOURS: "6"
      WAKE_STATE_FILE: "wakeup_state.json"
      HTTP_MAX_RETRIES: "2"
      BROWSER_MAX_RETRIES: "2"
      RETRY_BACKOFF_SECONDS: "2"
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Restore wake state cache
        uses: actions/cache@v4
        with:
          path: wakeup_state.json
          key: wakeup-state-${{ runner.os }}-${{ github.run_id }}
          restore-keys: |
            wakeup-state-${{ runner.os }}-

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: "3.x"

      - name: Install dependencies
        run: |
          pip install selenium requests

      - name: Run Python script to wake up Streamlit apps
        run: python wake_up_streamlit.py

      - name: Upload log file as artifact
        uses: actions/upload-artifact@v4
        with:
          name: wakeup-log
          path: wakeup_log.txt
