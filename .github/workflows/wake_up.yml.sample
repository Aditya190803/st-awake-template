name: Wake Up Streamlit Apps

on:
  push:
    branches:
      - main
  schedule:
      - cron: "0 * * * *"

jobs:
  wake-up:
    runs-on: ubuntu-latest
    env:
      WAKE_INTERVAL_HOURS: "10"
      ENFORCE_WAKE_INTERVAL: "1"
      WAKE_STATE_FILE: "wakeup_state.json"
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v5

      - name: Restore wake state cache
        uses: actions/cache@v5
        with:
          path: wakeup_state.json
          key: wakeup-state-${{ runner.os }}-${{ github.run_id }}
          restore-keys: |
            wakeup-state-${{ runner.os }}-

      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: "3.x"

      - name: Install dependencies
        run: |
          pip install -r requirements.txt

      - name: Run Python script to wake up Streamlit apps
        run: python wake_up_streamlit.py

      - name: Upload log file as artifact
        uses: actions/upload-artifact@v6
        with:
          name: wakeup-log
          path: wakeup_log.txt
